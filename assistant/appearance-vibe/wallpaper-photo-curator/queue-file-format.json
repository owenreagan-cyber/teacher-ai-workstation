{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wallpaper Photo Curator Queue File",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "queue_name",
    "queue_type",
    "max_candidates",
    "records",
    "created_at",
    "updated_at",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "queue_name": {
      "type": "string"
    },
    "queue_type": {
      "type": "string",
      "enum": ["wallpaper", "photo_widget", "mixed"]
    },
    "max_candidates": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "candidate_type",
          "queue_name",
          "queue_position",
          "queue_added_at",
          "queue_expires_at",
          "review_status",
          "review_decision",
          "source_name",
          "source_url",
          "candidate_url",
          "title",
          "content_rating",
          "nsfw_flag",
          "local_temp_path",
          "processed_output_path",
          "notes"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "candidate_type": {
            "type": "string",
            "enum": ["wallpaper", "photo_widget", "both"]
          },
          "queue_name": {
            "type": "string"
          },
          "queue_position": {
            "type": "integer",
            "minimum": 0
          },
          "queue_added_at": {
            "type": "string"
          },
          "queue_expires_at": {
            "type": "string"
          },
          "review_status": {
            "type": "string",
            "enum": ["unreviewed", "approved", "dismissed", "blocked", "needs_more_info"]
          },
          "review_decision": {
            "type": "string",
            "enum": [
              "none",
              "approve_for_processing",
              "dismiss_delete_candidate",
              "block_source",
              "needs_more_info"
            ]
          },
          "source_name": {
            "type": "string"
          },
          "source_url": {
            "type": "string"
          },
          "candidate_url": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "content_rating": {
            "type": "string",
            "enum": ["safe", "needs_review", "blocked"]
          },
          "nsfw_flag": {
            "type": "boolean"
          },
          "local_temp_path": {
            "type": "string"
          },
          "processed_output_path": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
