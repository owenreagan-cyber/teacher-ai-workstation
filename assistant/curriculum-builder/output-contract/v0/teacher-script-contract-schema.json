{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "teacher-ai-workstation/curriculum-output-contract/v0/teacher-script-contract-schema.json",
  "title": "Teacher Script Output Contract v0",
  "description": "Canonical v0 contract schema for teacher script planning metadata only.",
  "allOf": [
    {
      "$ref": "contract-envelope-schema.json"
    }
  ],
  "required": [
    "contract_version",
    "contract_status",
    "metadata_only",
    "read_only",
    "contract_id",
    "contract_type",
    "title",
    "subject",
    "grade_band",
    "course",
    "unit",
    "lesson",
    "registry_references",
    "teacher_only",
    "student_facing_allowed",
    "review_state",
    "approval_status",
    "lesson_context",
    "script_sections",
    "local_first_safety_flags",
    "non_activation_flags",
    "pedagogy_extensions",
    "metadata_extensions",
    "planning_notes",
    "created_by_manual_entry",
    "activation_status"
  ],
  "properties": {
    "contract_type": {
      "const": "teacher_script_contract"
    },
    "contract_status": {
      "const": "active_v0"
    },
    "activation_status": {
      "const": "contract_v0"
    },
    "review_state": {
      "type": "string",
      "enum": [
        "not_reviewed",
        "metadata_only",
        "teacher_reviewed",
        "needs_update",
        "retired"
      ]
    },
    "approval_status": {
      "type": "string",
      "enum": [
        "not_approved",
        "placeholder_approved",
        "blocked_placeholder",
        "approved",
        "rejected"
      ]
    },
    "lesson_context": {
      "type": "object",
      "required": ["pacing_reference", "delivery_mode", "focus_topic"],
      "additionalProperties": false,
      "properties": {
        "pacing_reference": { "type": "string", "minLength": 1 },
        "delivery_mode": { "type": "string", "const": "direct_instruction" },
        "focus_topic": { "type": "string", "minLength": 1 }
      }
    },
    "script_sections": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": [
          "section_id",
          "section_label",
          "teacher_script",
          "teacher_prompt",
          "student_response_expectation",
          "check_for_understanding",
          "timing_or_pacing_hint",
          "materials_or_prep_note"
        ],
        "additionalProperties": false,
        "properties": {
          "section_id": {
            "type": "string",
            "pattern": "^section-[0-9]{2}$"
          },
          "section_label": { "type": "string", "minLength": 1 },
          "teacher_script": { "type": "string", "minLength": 1 },
          "teacher_prompt": { "type": "string", "minLength": 1 },
          "student_response_expectation": { "type": "string", "minLength": 1 },
          "check_for_understanding": { "type": "string", "minLength": 1 },
          "timing_or_pacing_hint": { "type": "string", "minLength": 1 },
          "materials_or_prep_note": { "type": "string", "minLength": 1 }
        }
      }
    },
    "non_activation_flags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 5
    },
    "pedagogy_extensions": {
      "type": "object"
    },
    "metadata_extensions": {
      "type": "object"
    }
  }
}
