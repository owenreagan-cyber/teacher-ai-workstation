{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "teacher-ai-workstation/curriculum-output-contract/v0/worksheet-contract-schema.json",
  "title": "Worksheet Output Contract v0",
  "description": "Canonical v0 contract schema for worksheet planning metadata only.",
  "allOf": [
    {
      "$ref": "contract-envelope-schema.json"
    }
  ],
  "required": [
    "contract_version",
    "contract_status",
    "metadata_only",
    "read_only",
    "contract_id",
    "contract_type",
    "title",
    "subject",
    "grade_band",
    "course",
    "unit",
    "lesson",
    "registry_references",
    "teacher_only",
    "student_facing_allowed",
    "review_state",
    "approval_status",
    "worksheet_context",
    "exercise_placeholders",
    "local_first_safety_flags",
    "non_activation_flags",
    "pedagogy_extensions",
    "metadata_extensions",
    "planning_notes",
    "created_by_manual_entry",
    "activation_status"
  ],
  "properties": {
    "contract_type": {
      "const": "worksheet_contract"
    },
    "contract_status": {
      "const": "active_v0"
    },
    "activation_status": {
      "const": "contract_v0"
    },
    "review_state": {
      "type": "string",
      "enum": [
        "not_reviewed",
        "metadata_only",
        "teacher_reviewed",
        "needs_update",
        "retired"
      ]
    },
    "approval_status": {
      "type": "string",
      "enum": [
        "not_approved",
        "placeholder_approved",
        "blocked_placeholder",
        "approved",
        "rejected"
      ]
    },
    "worksheet_context": {
      "type": "object",
      "required": ["pacing_reference", "worksheet_format", "focus_topic"],
      "additionalProperties": false,
      "properties": {
        "pacing_reference": { "type": "string", "minLength": 1 },
        "worksheet_format": { "type": "string", "const": "practice_worksheet" },
        "focus_topic": { "type": "string", "minLength": 1 }
      }
    },
    "exercise_placeholders": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": [
          "exercise_id",
          "prompt_placeholder",
          "response_format_placeholder",
          "answer_key_placeholder",
          "difficulty_hint_placeholder"
        ],
        "additionalProperties": false,
        "properties": {
          "exercise_id": {
            "type": "string",
            "pattern": "^exercise-[0-9]{2}$"
          },
          "prompt_placeholder": { "type": "string", "minLength": 1 },
          "response_format_placeholder": { "type": "string", "minLength": 1 },
          "answer_key_placeholder": { "type": "string", "minLength": 1 },
          "difficulty_hint_placeholder": { "type": "string", "minLength": 1 }
        }
      }
    },
    "non_activation_flags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 5
    },
    "pedagogy_extensions": {
      "type": "object"
    },
    "metadata_extensions": {
      "type": "object"
    }
  }
}
