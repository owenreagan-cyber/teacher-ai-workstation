  case "$1" in
    morning-brief) printf '%s\n' "assistant/workflows/morning-brief.md" ;;
    project-review) printf '%s\n' "assistant/workflows/project-review.md" ;;
    lesson-support) printf '%s\n' "assistant/workflows/lesson-support.md" ;;
    email-style-support) printf '%s\n' "assistant/workflows/email-style-support.md" ;;
    request-training-materials) printf '%s\n' "assistant/workflows/request-training-materials.md" ;;
    intake-review) printf '%s\n' "assistant/workflows/intake-review.md" ;;
    verify-before-use) printf '%s\n' "assistant/workflows/verify-before-use.md" ;;
    app-development-support) printf '%s\n' "assistant/workflows/app-development-support.md" ;;
