    assistant/memory/writing-style-rules.md) echo "approved writing style rules" ;;
    assistant/memory/preferences.md) echo "stable tool and workflow preferences" ;;
    assistant/memory/decisions.md) echo "meaningful project decisions" ;;
    assistant/memory/active-priorities.md) echo "current roadmap and priorities" ;;
    assistant/memory/memory-review-checklist.md) echo "manual memory review checklist" ;;
    assistant/memory/memory-log.md) echo "manual memory change log" ;;
    *) echo "memory file" ;;
  esac
}

intake_purpose() {
