    assistant/intake/rejected-context.md) echo "minimal rejected-item index" ;;
    assistant/intake/quarantine.md) echo "quarantine index for review-needed material" ;;
    assistant/intake/intake-log.md) echo "chronological intake activity log" ;;
    assistant/intake/intake-review-checklist.md) echo "manual review checklist" ;;
    assistant/intake/templates/intake-item-template.md) echo "new intake item template" ;;
    assistant/intake/templates/review-decision-template.md) echo "review decision template" ;;
    assistant/intake/templates/sanitized-summary-template.md) echo "sanitized summary template" ;;
    *) echo "intake file" ;;
  esac
}

file_modified_epoch() {
  local file="$1"
  local modified=""
  modified="$(stat -f%m "${file}" 2>/dev/null || true)"
  if [[ -z "${modified}" ]]; then
    modified="$(stat -c%Y "${file}" 2>/dev/null || true)"
  fi
  printf '%s\n' "${modified:-0}"
}

file_modified_date() {
  local file="$1"
  local modified_epoch
  modified_epoch="$(file_modified_epoch "${file}")"
  if [[ "${modified_epoch}" =~ ^[0-9]+$ ]] && (( modified_epoch > 0 )); then
    date -r "${modified_epoch}" "+%Y-%m-%d" 2>/dev/null || date -d "@${modified_epoch}" "+%Y-%m-%d" 2>/dev/null || echo "unknown"
  else
    echo "unknown"
  fi
}

count_markdown_heading() {
  local file="$1"
  local pattern="$2"
  if [[ -f "${file}" ]]; then
    grep -Ec "${pattern}" "${file}" || true
  else
    echo "0"
  fi
}

count_markdown_text() {
  local file="$1"
  local pattern="$2"
  if [[ -f "${file}" ]]; then
    grep -Eic "${pattern}" "${file}" || true
  else
    echo "0"
  fi
}

intake_queue_count() {
  count_markdown_heading "$1" '^### Intake Item: ITEM-[0-9]{4}'
}

approved_intake_count() {
  count_markdown_heading "$1" '^### Approved Item: APPROVED-[0-9]{4}'
}

rejected_intake_count() {
  count_markdown_heading "$1" '^### Rejected Item: REJECTED-[0-9]{4}'
}

quarantined_intake_count() {
  count_markdown_heading "$1" '^### Quarantined Item: QUARANTINE-[0-9]{4}'
}

last_intake_log_heading() {
  local file="$1"
  if [[ -f "${file}" ]]; then
    grep -E '^### ' "${file}" | tail -1 || true
  fi
}

is_stale_memory_file() {
  local repo_root="$1"
  local relative_path="$2"
  local abs_path="${repo_root}/${relative_path}"
  local modified_epoch
  local now_epoch

  case "${relative_path}" in
    assistant/memory/*) ;;
    *) return 1 ;;
  esac

  [[ -f "${abs_path}" ]] || return 1
  modified_epoch="$(file_modified_epoch "${abs_path}")"
  [[ "${modified_epoch}" =~ ^[0-9]+$ ]] || return 1
  now_epoch="$(date +%s)"
  (( now_epoch - modified_epoch > STALE_MEMORY_SECONDS ))
}

print_included_file_for_show_context() {
  local repo_root="$1"
  local relative_path="$2"
  if is_stale_memory_file "${repo_root}" "${relative_path}"; then
    echo "- ${relative_path} [STALE?]"
  else
    echo "- ${relative_path}"
  fi
}

show_intake_status() {
  local repo_root="$1"
  local relative_path
  local abs_path
  local size_bytes
  local modified_date

  echo "Chief of Staff Intake Status"
  echo
  echo "Repo root: ${repo_root}"
  echo
  status_line_dir "assistant/intake" "${repo_root}/assistant/intake"
  status_line_dir "assistant/intake/raw" "${repo_root}/assistant/intake/raw"
  status_line_dir "assistant/intake/quarantine-files" "${repo_root}/assistant/intake/quarantine-files"
  status_line_dir "assistant/intake/approved-files" "${repo_root}/assistant/intake/approved-files"
  echo
  echo "Counts:"
  echo "- Pending queue entries: $(intake_queue_count "${repo_root}/assistant/intake/review-queue.md")"
  echo "- Approved entries: $(approved_intake_count "${repo_root}/assistant/intake/approved-context.md")"
  echo "- Rejected entries: $(rejected_intake_count "${repo_root}/assistant/intake/rejected-context.md")"
  echo "- Quarantined entries: $(quarantined_intake_count "${repo_root}/assistant/intake/quarantine.md")"
  echo

  while IFS= read -r relative_path; do
    abs_path="${repo_root}/${relative_path}"
    if [[ -f "${abs_path}" ]]; then
      echo "PASS: ${relative_path}"
      size_bytes="$(file_size_bytes "${abs_path}")"
      modified_date="$(file_modified_date "${abs_path}")"
      echo "Size: ${size_bytes} bytes"
      echo "Modified: ${modified_date}"
      echo "Purpose: $(intake_purpose "${relative_path}")"
    else
      echo "WARN: ${relative_path} missing"
      echo "Purpose: $(intake_purpose "${relative_path}")"
    fi
    echo
  done < <(intake_files_all)
}

INTAKE_WARNING_COUNT=0

add_intake_warning() {
  local print_warnings="$1"
  local relative_path="$2"
  local category="$3"

  INTAKE_WARNING_COUNT=$((INTAKE_WARNING_COUNT + 1))
  if [[ "${print_warnings}" == "yes" ]]; then
    echo "WARN: ${relative_path} may contain ${category}."
  fi
}

scan_intake_for_warnings() {
  local repo_root="$1"
  local print_warnings="${2:-no}"
  local relative_path
  local abs_path

  INTAKE_WARNING_COUNT=0

  while IFS= read -r relative_path; do
    abs_path="${repo_root}/${relative_path}"
    [[ -f "${abs_path}" ]] || continue

    if grep -Eiq '(^|[^[:alnum:]_])password[[:space:]]*[:=][[:space:]]*[^[:space:]]+' "${abs_path}"; then
      add_intake_warning "${print_warnings}" "${relative_path}" "assigned password-like text"
    fi
    if grep -Eiq '(^|[^[:alnum:]_])api[_-]?key[[:space:]]*[:=][[:space:]]*[^[:space:]]+' "${abs_path}"; then
      add_intake_warning "${print_warnings}" "${relative_path}" "assigned api_key-like text"
    fi
    if grep -Eiq '(^|[^[:alnum:]_])secret[[:space:]]*[:=][[:space:]]*[^[:space:]]+' "${abs_path}"; then
      add_intake_warning "${print_warnings}" "${relative_path}" "assigned secret-like text"
    fi
    if grep -Eiq '(^|[^[:alnum:]_])token[[:space:]]*[:=][[:space:]]*[^[:space:]]+' "${abs_path}"; then
      add_intake_warning "${print_warnings}" "${relative_path}" "assigned token-like text"
    fi
    if grep -Eq -- '-----BEGIN [A-Z ]*PRIVATE KEY-----' "${abs_path}"; then
      add_intake_warning "${print_warnings}" "${relative_path}" "private-key-block markers"
    fi
    if grep -Eiq '(^|[^[:alnum:]_])student[_-]?id[[:space:]]*[:=][[:space:]]*[^[:space:]]+' "${abs_path}"; then
      add_intake_warning "${print_warnings}" "${relative_path}" "student_id-like text"
    fi
    if grep -Eq '[0-9]{3}-[0-9]{2}-[0-9]{4}' "${abs_path}"; then
      add_intake_warning "${print_warnings}" "${relative_path}" "SSN-like text"
    fi
    if grep -Eiq '[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}' "${abs_path}"; then
      add_intake_warning "${print_warnings}" "${relative_path}" "email-like text"
    fi
    if grep -Eq '(\([0-9]{3}\)[[:space:]]*|[0-9]{3}[-.[:space:]])[0-9]{3}[-.[:space:]][0-9]{4}' "${abs_path}"; then
      add_intake_warning "${print_warnings}" "${relative_path}" "phone-number-like text"
    fi
  done < <(intake_files_validate)
}

validate_intake() {
  local repo_root="$1"

  echo "Chief of Staff Intake Validation"
  echo
  echo "This is a quick warning system, not a security guarantee."
  echo

  scan_intake_for_warnings "${repo_root}" "yes"

  if (( INTAKE_WARNING_COUNT > 0 )); then
    echo
    echo "Review warnings manually before including intake. Warnings may be false positives."
    echo "Values are not printed here; inspect the named files directly if needed."
    exit 1
  fi

  echo "PASS: No obvious sensitive-data warning patterns found in intake Markdown files."
}

show_intake_summary() {
  local repo_root="$1"
  local review_queue="${repo_root}/assistant/intake/review-queue.md"
  local approved_context="${repo_root}/assistant/intake/approved-context.md"
  local rejected_context="${repo_root}/assistant/intake/rejected-context.md"
  local quarantine_index="${repo_root}/assistant/intake/quarantine.md"
  local intake_log="${repo_root}/assistant/intake/intake-log.md"
  local last_heading

  scan_intake_for_warnings "${repo_root}" "no"
  last_heading="$(last_intake_log_heading "${intake_log}")"

  echo "Chief of Staff Intake Summary"
  echo
  echo "- Pending queue entries: $(intake_queue_count "${review_queue}")"
  echo "- Approved entries: $(approved_intake_count "${approved_context}")"
  echo "- Rejected entries: $(rejected_intake_count "${rejected_context}")"
  echo "- Quarantined entries: $(quarantined_intake_count "${quarantine_index}")"
  echo "- Needs-more-context mentions: $(count_markdown_text "${review_queue}" 'needs[- ]more[- ]context|needs more context')"
  echo "- Deferred mentions: $(count_markdown_text "${review_queue}" 'deferred')"
  echo "- Last intake-log heading: ${last_heading:-none found}"
  if (( INTAKE_WARNING_COUNT > 0 )); then
    echo "- Intake validation: would warn (${INTAKE_WARNING_COUNT} warning(s)); run --validate-intake for details."
  else
    echo "- Intake validation: PASS"
  fi
}

show_intake_diff() {
  local repo_root="$1"
  local diff_output

  diff_output="$(git -C "${repo_root}" diff -- assistant/intake/ .gitignore)"
  if [[ -z "${diff_output}" ]]; then
    echo "No uncommitted intake changes found."
  else
    printf '%s\n' "${diff_output}"
  fi
}

next_intake_id() {
  local repo_root="$1"
  local queue_file="${repo_root}/assistant/intake/review-queue.md"
  local max_id=""

  if [[ -f "${queue_file}" ]]; then
    max_id="$(grep -Eoh 'ITEM-[0-9]{4}' "${queue_file}" | sed 's/ITEM-//' | sort -n | tail -1 || true)"
  fi

  if [[ -z "${max_id}" ]]; then
    echo "ITEM-0001"
  else
    printf 'ITEM-%04d\n' "$((10#${max_id} + 1))"
  fi
}

show_memory_status() {
  local repo_root="$1"
  local relative_path
  local abs_path
  local size_bytes
  local modified_date

  echo "Chief of Staff Memory Status"
  echo
  echo "Repo root: ${repo_root}"
  echo

  if [[ -d "${repo_root}/assistant/memory" ]]; then
    echo "PASS: assistant/memory exists"
  else
    echo "WARN: assistant/memory missing"
  fi
  echo

  while IFS= read -r relative_path; do
    abs_path="${repo_root}/${relative_path}"
    if [[ -f "${abs_path}" ]]; then
      if is_stale_memory_file "${repo_root}" "${relative_path}"; then
        echo "WARN: ${relative_path} [STALE?]"
      else
        echo "PASS: ${relative_path}"
      fi
      size_bytes="$(file_size_bytes "${abs_path}")"
      modified_date="$(file_modified_date "${abs_path}")"
      echo "Size: ${size_bytes} bytes"
      echo "Modified: ${modified_date}"
      echo "Purpose: $(memory_purpose "${relative_path}")"
    else
      echo "WARN: ${relative_path} missing"
      echo "Purpose: $(memory_purpose "${relative_path}")"
    fi
    echo
  done < <(memory_files_all)
}

validate_memory() {
  local repo_root="$1"
  local warnings=0
  local relative_path
  local abs_path

  echo "Chief of Staff Memory Validation"
  echo
  echo "This is a quick warning system, not a security guarantee."
  echo

  while IFS= read -r relative_path; do
    abs_path="${repo_root}/${relative_path}"
    [[ -f "${abs_path}" ]] || continue

    if grep -Eiq '\bpassword\b' "${abs_path}"; then
      echo "WARN: ${relative_path} may contain password-like text."
      warnings=$((warnings + 1))
    fi
    if grep -Eiq 'api[_-]?key' "${abs_path}"; then
      echo "WARN: ${relative_path} may contain api_key-like text."
      warnings=$((warnings + 1))
    fi
    if grep -Eiq '\bsecret\b' "${abs_path}"; then
      echo "WARN: ${relative_path} may contain secret-like text."
      warnings=$((warnings + 1))
    fi
    if grep -Eiq '\btoken\b' "${abs_path}"; then
      echo "WARN: ${relative_path} may contain token-like text."
      warnings=$((warnings + 1))
    fi
    if grep -Eiq 'private key' "${abs_path}"; then
      echo "WARN: ${relative_path} may contain private-key-like text."
      warnings=$((warnings + 1))
    fi
    if grep -Eiq 'student[_-]?id' "${abs_path}"; then
      echo "WARN: ${relative_path} may contain student_id-like text."
      warnings=$((warnings + 1))
    fi
    if grep -Eq '[0-9]{3}-[0-9]{2}-[0-9]{4}' "${abs_path}"; then
      echo "WARN: ${relative_path} may contain SSN-like text."
      warnings=$((warnings + 1))
    fi
    if grep -Eiq '[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}' "${abs_path}"; then
      echo "WARN: ${relative_path} may contain email-like text."
      warnings=$((warnings + 1))
    fi
    if grep -Eq '(\([0-9]{3}\)[[:space:]]*|[0-9]{3}[-.[:space:]])[0-9]{3}[-.[:space:]][0-9]{4}' "${abs_path}"; then
      echo "WARN: ${relative_path} may contain phone-number-like text."
      warnings=$((warnings + 1))
    fi
  done < <(memory_files_validate)

  if (( warnings > 0 )); then
    echo
    echo "Review warnings manually before including memory. Warnings may be false positives."
    exit 1
  fi

  echo "PASS: No obvious sensitive-data warning patterns found in memory files."
}

show_status() {
  local repo_root="$1"
  echo "${VERSION}"
  echo "Resolved repo root: ${repo_root}"
  echo
  status_line_file "assistant/chief-of-staff.md" "${repo_root}/assistant/chief-of-staff.md"
  status_line_file "assistant/permissions.md" "${repo_root}/assistant/permissions.md"
  status_line_file "assistant/failure-recovery-policy.md" "${repo_root}/assistant/failure-recovery-policy.md"
  status_line_file "assistant/sensitivity-rules.md" "${repo_root}/assistant/sensitivity-rules.md"
  status_line_file "assistant/model-routing.md" "${repo_root}/assistant/model-routing.md"
  status_line_file "assistant/writing-style.md" "${repo_root}/assistant/writing-style.md"
  status_line_dir "assistant/workflows" "${repo_root}/assistant/workflows"

  if command -v llm >/dev/null 2>&1; then
    echo "PASS: llm is installed/on PATH"
  else
    echo "WARN: llm is not installed or not on PATH"
  fi

  status_line_file "approved-samples.md" "${repo_root}/assistant/training/writing-samples/approved-samples.md"

  if [[ -f "${repo_root}/assistant/training/writing-samples/raw-inbox.md" ]]; then
    echo "PASS: raw-inbox.md exists and is excluded"
  else
    echo "WARN: raw-inbox.md missing"
  fi

  if [[ -f "${repo_root}/assistant/training/writing-samples/rejected-samples.md" ]]; then
    echo "PASS: rejected-samples.md exists and is excluded"
  else
    echo "WARN: rejected-samples.md missing"
  fi

  echo "Memory status: run --memory-status for detailed memory file status."
  status_line_dir "assistant/memory" "${repo_root}/assistant/memory"
  while IFS= read -r memory_file; do
    status_line_file "${memory_file}" "${repo_root}/${memory_file}"
  done < <(memory_files_all)
  echo "Intake status: run --intake-status for detailed intake file status."
  echo "Intake summary: run --intake-summary for queue counts."
  echo "Intake validation: run --validate-intake before including intake in a real model call."
}

chief_preflight() {
  local repo_root="$1"
  local script_path
  local failures=0
  local output_file

  script_path="$(absolute_file_path "${BASH_SOURCE[0]}")"

  echo "Chief of Staff Preflight"
  echo
  echo "Repo root: ${repo_root}"
  echo "No model will be called."
  echo

  run_preflight_check() {
    local label="$1"
    local optional="$2"
    shift 2
    output_file="$(mktemp "${TMPDIR:-/tmp}/chief-preflight.XXXXXX")"
    if CHIEF_OF_STAFF_REPO="${repo_root}" "$@" >"${output_file}" 2>&1; then
      echo "PASS: ${label}"
    else
      if grep -q "Unknown option" "${output_file}" && [[ "${optional}" == "optional" ]]; then
        echo "WARN: ${label} is not implemented."
      elif [[ "${optional}" == "optional" ]]; then
        echo "WARN: ${label} returned a warning or nonzero result."
        sed 's/^/  /' "${output_file}"
      else
        echo "FAIL: ${label} failed."
        sed 's/^/  /' "${output_file}"
        failures=$((failures + 1))
      fi
    fi
    rm -f "${output_file}"
  }

  run_preflight_check "--status" "required" "${script_path}" --status
  run_preflight_check "--memory-status" "optional" "${script_path}" --memory-status
  run_preflight_check "--validate-memory" "optional" "${script_path}" --validate-memory
  run_preflight_check "--intake-status" "optional" "${script_path}" --intake-status
  run_preflight_check "--validate-intake" "optional" "${script_path}" --validate-intake

  echo
  if (( failures > 0 )); then
    echo "Chief of Staff Preflight Result: FAIL"
    return 1
  fi

  echo "Chief of Staff Preflight Result: PASS"
}

