is_repo_root() {
  local candidate="$1"
  [[ -d "${candidate}" ]] &&
    [[ -f "${candidate}/README.md" ]] &&
    [[ -f "${candidate}/assistant/chief-of-staff.md" ]] &&
    [[ -d "${candidate}/assistant/workflows" ]]
}

script_dir() {
  local source_dir
  source_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  printf '%s\n' "${source_dir}"
}

resolve_repo_root() {
  local candidate=""

  if [[ -n "${CHIEF_OF_STAFF_REPO:-}" ]]; then
    candidate="$(cd "${CHIEF_OF_STAFF_REPO}" 2>/dev/null && pwd -P || true)"
    if is_repo_root "${candidate}"; then
      printf '%s\n' "${candidate}"
      return 0
    fi
    die "CHIEF_OF_STAFF_REPO is set but does not point to the teacher-ai-workstation repo root."
  fi

  candidate="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -n "${candidate}" ]] && is_repo_root "${candidate}"; then
    printf '%s\n' "${candidate}"
    return 0
  fi

  candidate="$(cd "$(script_dir)/.." && pwd -P)"
  if is_repo_root "${candidate}"; then
    printf '%s\n' "${candidate}"
    return 0
  fi

  die "Could not find the teacher-ai-workstation repo root. Run this from inside the repo or set CHIEF_OF_STAFF_REPO=/path/to/teacher-ai-workstation."
}

file_size_bytes() {
  local file="$1"
  local size=""
  size="$(stat -f%z "${file}" 2>/dev/null || true)"
  if [[ -z "${size}" ]]; then
    size="$(stat -c%s "${file}" 2>/dev/null || true)"
  fi
  printf '%s\n' "${size:-0}"
}

absolute_file_path() {
  local path="$1"
  local dir
  local base
  dir="$(dirname "${path}")"
  base="$(basename "${path}")"
  (cd "${dir}" && printf '%s/%s\n' "$(pwd -P)" "${base}")
}

source_label_for_path() {
  local abs_path="$1"
  local repo_root="$2"
  case "${abs_path}" in
    "${repo_root}/"*) printf '%s\n' "${abs_path#"${repo_root}/"}" ;;
    *) printf '%s\n' "${abs_path}" ;;
  esac
}

append_source() {
  local repo_root="$1"
  local relative_path="$2"
  local abs_path="${repo_root}/${relative_path}"

  printf '\n---\n'
  printf 'SOURCE: %s\n' "${relative_path}"
  printf -- '---\n\n'
  cat "${abs_path}"
  printf '\n'
}

append_context_source() {
  local repo_root="$1"
  local abs_path="$2"
  local label
  label="$(source_label_for_path "${abs_path}" "${repo_root}")"

  printf '\n---\n'
  printf 'SOURCE: %s\n' "${label}"
  printf -- '---\n\n'
  cat "${abs_path}"
  printf '\n'
}

status_line_file() {
  local label="$1"
  local path="$2"
  if [[ -f "${path}" ]]; then
    printf 'PASS: %s exists\n' "${label}"
  else
    printf 'WARN: %s missing\n' "${label}"
  fi
}

status_line_dir() {
  local label="$1"
  local path="$2"
  if [[ -d "${path}" ]]; then
    printf 'PASS: %s exists\n' "${label}"
  else
    printf 'WARN: %s missing\n' "${label}"
  fi
}

