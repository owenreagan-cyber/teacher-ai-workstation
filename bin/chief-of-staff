      bash "${wallpaper_source_allowlist_status_script}"
      exit 0
      ;;
    --wallpaper-photo-source-allowlist-validator)
      repo_root="$(resolve_repo_root)"
      wallpaper_source_allowlist_validator_script="${repo_root}/scripts/wallpaper-photo-source-allowlist-validator.sh"
      if [[ ! -f "${wallpaper_source_allowlist_validator_script}" ]]; then
        die "Wallpaper photo source allowlist validator script is missing: scripts/wallpaper-photo-source-allowlist-validator.sh"
      fi
      shift
      bash "${wallpaper_source_allowlist_validator_script}" "$@"
      exit 0
      ;;
    --wallpaper-photo-simulated-discovery-status)
      repo_root="$(resolve_repo_root)"
      wallpaper_simulated_discovery_status_script="${repo_root}/scripts/wallpaper-photo-simulated-discovery-status.sh"
      if [[ ! -f "${wallpaper_simulated_discovery_status_script}" ]]; then
        die "Wallpaper photo simulated discovery status script is missing: scripts/wallpaper-photo-simulated-discovery-status.sh"
      fi
      bash "${wallpaper_simulated_discovery_status_script}"
      exit 0
      ;;
    --wallpaper-photo-simulated-discovery-validator)
      repo_root="$(resolve_repo_root)"
      wallpaper_simulated_discovery_validator_script="${repo_root}/scripts/wallpaper-photo-simulated-discovery-validator.sh"
      if [[ ! -f "${wallpaper_simulated_discovery_validator_script}" ]]; then
        die "Wallpaper photo simulated discovery validator script is missing: scripts/wallpaper-photo-simulated-discovery-validator.sh"
      fi
      shift
      bash "${wallpaper_simulated_discovery_validator_script}" "$@"
      exit 0
      ;;
    --wallpaper-photo-review-ui-prototype-status)
      repo_root="$(resolve_repo_root)"
