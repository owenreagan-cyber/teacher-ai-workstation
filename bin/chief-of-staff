      if [[ ! -f "${wallpaper_notification_plan_validator_script}" ]]; then
        die "Wallpaper photo notification plan validator script is missing: scripts/wallpaper-photo-notification-plan-validator.sh"
      fi
      shift
      bash "${wallpaper_notification_plan_validator_script}" "$@"
      exit 0
      ;;
    --wallpaper-photo-rotation-handoff-safety-status)
      repo_root="$(resolve_repo_root)"
      wallpaper_rotation_handoff_safety_status_script="${repo_root}/scripts/wallpaper-photo-rotation-handoff-safety-status.sh"
      if [[ ! -f "${wallpaper_rotation_handoff_safety_status_script}" ]]; then
        die "Wallpaper photo rotation handoff safety status script is missing: scripts/wallpaper-photo-rotation-handoff-safety-status.sh"
      fi
      bash "${wallpaper_rotation_handoff_safety_status_script}"
      exit 0
      ;;
    --wallpaper-photo-rotation-handoff-validator)
      repo_root="$(resolve_repo_root)"
      wallpaper_rotation_handoff_validator_script="${repo_root}/scripts/wallpaper-photo-rotation-handoff-validator.sh"
      if [[ ! -f "${wallpaper_rotation_handoff_validator_script}" ]]; then
        die "Wallpaper photo rotation handoff validator script is missing: scripts/wallpaper-photo-rotation-handoff-validator.sh"
      fi
      shift
      bash "${wallpaper_rotation_handoff_validator_script}" "$@"
      exit 0
      ;;
    --return-to-core-status)
      repo_root="$(resolve_repo_root)"
      return_to_core_status_script="${repo_root}/scripts/return-to-chief-of-staff-core-status.sh"
      if [[ ! -f "${return_to_core_status_script}" ]]; then
        die "Return to Chief of Staff core status script is missing: scripts/return-to-chief-of-staff-core-status.sh"
      fi
      bash "${return_to_core_status_script}"
      exit 0
      ;;
    --command-launcher-status)
      repo_root="$(resolve_repo_root)"
      command_launcher_status_script="${repo_root}/scripts/command-launcher-status.sh"
      if [[ ! -f "${command_launcher_status_script}" ]]; then
        die "Command launcher status script is missing: scripts/command-launcher-status.sh"
      fi
      bash "${command_launcher_status_script}"
      exit 0
      ;;
    --cursor-workflow-status)
      repo_root="$(resolve_repo_root)"
      cursor_workflow_status_script="${repo_root}/scripts/cursor-workflow-status.sh"
      if [[ ! -f "${cursor_workflow_status_script}" ]]; then
        die "Cursor workflow status script is missing: scripts/cursor-workflow-status.sh"
      fi
      bash "${cursor_workflow_status_script}"
      exit 0
      ;;
    --developer-status)
      repo_root="$(resolve_repo_root)"
      developer_status_script="${repo_root}/scripts/developer-mode-status.sh"
      if [[ ! -f "${developer_status_script}" ]]; then
        die "Developer Mode status script is missing: scripts/developer-mode-status.sh"
      fi
      bash "${developer_status_script}"
      exit 0
      ;;
    --create-developer-project)
      if [[ -z "${2:-}" || -z "${3:-}" ]]; then
        echo "Usage: bin/chief-of-staff --create-developer-project TEMPLATE_NAME PROJECT_SLUG" >&2
        exit 1
      fi
      repo_root="$(resolve_repo_root)"
      create_project_script="${repo_root}/scripts/create-developer-project.sh"
      if [[ ! -f "${create_project_script}" ]]; then
        die "Developer project creation script is missing: scripts/create-developer-project.sh"
      fi
      bash "${create_project_script}" "$2" "$3"
      exit 0
      ;;
    --status)
      repo_root="$(resolve_repo_root)"
      show_status "${repo_root}"
      exit 0
      ;;
    --memory-status)
      repo_root="$(resolve_repo_root)"
      show_memory_status "${repo_root}"
      exit 0
      ;;
    --validate-memory)
      repo_root="$(resolve_repo_root)"
      validate_memory "${repo_root}"
      exit 0
      ;;
    --intake-status)
      repo_root="$(resolve_repo_root)"
      show_intake_status "${repo_root}"
      exit 0
      ;;
    --intake-summary)
      repo_root="$(resolve_repo_root)"
      show_intake_summary "${repo_root}"
      exit 0
      ;;
    --intake-diff)
      repo_root="$(resolve_repo_root)"
      show_intake_diff "${repo_root}"
      exit 0
      ;;
    --next-intake-id)
      repo_root="$(resolve_repo_root)"
      next_intake_id "${repo_root}"
      exit 0
      ;;
    --validate-intake)
      repo_root="$(resolve_repo_root)"
      validate_intake "${repo_root}"
      exit 0
      ;;
    --preflight)
      repo_root="$(resolve_repo_root)"
      chief_preflight "${repo_root}"
      exit 0
      ;;
    --list-workflows)
      list_workflows
      exit 0
      ;;
    --workflow)
      [[ $# -ge 2 ]] || die "--workflow requires a name."
      workflow="$2"
      shift 2
      ;;
    --question)
      [[ $# -ge 2 ]] || die "--question requires text."
      question="$2"
      shift 2
      ;;
    --context)
      [[ $# -ge 2 ]] || die "--context requires a file path."
      contexts+=("$2")
      shift 2
      ;;
    --include-approved-writing-samples)
      include_approved_samples=1
      shift
      ;;
    --include-memory)
      include_all_memory=1
      shift
      ;;
    --include-project-memory)
      include_project_memory=1
      shift
      ;;
    --include-writing-style-memory)
      include_writing_style_memory=1
      shift
      ;;
    --include-teaching-context-memory)
      include_teaching_context_memory=1
      shift
      ;;
    --include-preferences-memory)
      include_preferences_memory=1
      shift
      ;;
    --include-decisions-memory)
      include_decisions_memory=1
      shift
      ;;
    --include-active-priorities-memory)
      include_active_priorities_memory=1
      shift
      ;;
    --include-approved-intake)
      include_approved_intake=1
      shift
      ;;
    --include-intake-policy)
      include_intake_policy=1
      shift
      ;;
    --include-intake-queue)
      include_intake_queue=1
      shift
      ;;
    --include-intake-checklist)
      include_intake_checklist=1
      shift
      ;;
    --model)
      [[ $# -ge 2 ]] || die "--model requires a model name."
      model="$2"
      shift 2
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    --show-context)
      show_context=1
      shift
      ;;
    --no-model)
      no_model=1
      shift
      ;;
    --force-large-context)
      force_large_context=1
      shift
      ;;
    --force-sensitive-context)
      force_sensitive_context=1
      shift
      ;;
    *)
      die "Unknown option: $1. Run bin/chief-of-staff --help for usage."
      ;;
  esac
done

repo_root="$(resolve_repo_root)"

[[ -n "${workflow}" ]] || die "--workflow is required for a Chief of Staff run. Use --list-workflows to see options."
workflow_relative="$(workflow_path_for_name "${workflow}" || true)"
if [[ -z "${workflow_relative}" ]]; then
  echo "Unknown workflow: ${workflow}" >&2
  echo "Available workflows:" >&2
  list_workflows >&2
  exit 1
fi

[[ -f "${repo_root}/${workflow_relative}" ]] || die "Workflow file is missing: ${workflow_relative}"

base_docs=(
  "assistant/chief-of-staff.md"
  "assistant/permissions.md"
  "assistant/failure-recovery-policy.md"
  "assistant/sensitivity-rules.md"
  "assistant/model-routing.md"
  "assistant/writing-style.md"
)

included_files=()
for base_doc in "${base_docs[@]}"; do
  [[ -f "${repo_root}/${base_doc}" ]] || die "Required base doc is missing: ${base_doc}"
  included_files+=("${base_doc}")
done

included_files+=("${workflow_relative}")

memory_relatives=()
add_memory_relative() {
  local relative_path="$1"
  local existing
  for existing in "${memory_relatives[@]+"${memory_relatives[@]}"}"; do
    [[ "${existing}" == "${relative_path}" ]] && return 0
  done
  [[ -f "${repo_root}/${relative_path}" ]] || die "Requested memory file is missing: ${relative_path}"
  memory_relatives+=("${relative_path}")
}

if (( include_all_memory == 1 )); then
  while IFS= read -r memory_file; do
    add_memory_relative "${memory_file}"
  done < <(memory_files_approved)
fi

if (( include_project_memory == 1 )); then
  add_memory_relative "assistant/memory/projects.md"
fi
if (( include_teaching_context_memory == 1 )); then
  add_memory_relative "assistant/memory/teaching-context.md"
fi
if (( include_writing_style_memory == 1 )); then
  add_memory_relative "assistant/memory/writing-style-rules.md"
fi
if (( include_preferences_memory == 1 )); then
  add_memory_relative "assistant/memory/preferences.md"
fi
if (( include_decisions_memory == 1 )); then
  add_memory_relative "assistant/memory/decisions.md"
fi
if (( include_active_priorities_memory == 1 )); then
  add_memory_relative "assistant/memory/active-priorities.md"
fi

for memory_relative in "${memory_relatives[@]+"${memory_relatives[@]}"}"; do
  included_files+=("${memory_relative}")
done

intake_relatives=()
add_intake_relative() {
  local relative_path="$1"
  local existing
  for existing in "${intake_relatives[@]+"${intake_relatives[@]}"}"; do
    [[ "${existing}" == "${relative_path}" ]] && return 0
  done
  [[ -f "${repo_root}/${relative_path}" ]] || die "Requested intake file is missing: ${relative_path}"
  intake_relatives+=("${relative_path}")
}

if (( include_approved_intake == 1 )); then
  add_intake_relative "assistant/intake/approved-context.md"
fi
if (( include_intake_policy == 1 )); then
  add_intake_relative "assistant/intake/intake-policy.md"
fi
if (( include_intake_queue == 1 )); then
  add_intake_relative "assistant/intake/review-queue.md"
fi
if (( include_intake_checklist == 1 )); then
  add_intake_relative "assistant/intake/intake-review-checklist.md"
fi

for intake_relative in "${intake_relatives[@]+"${intake_relatives[@]}"}"; do
  included_files+=("${intake_relative}")
done

approved_samples_relative="assistant/training/writing-samples/approved-samples.md"
if (( include_approved_samples == 1 )); then
  if [[ -f "${repo_root}/${approved_samples_relative}" ]]; then
    included_files+=("${approved_samples_relative}")
  else
    echo "WARN: approved writing samples requested, but ${approved_samples_relative} does not exist." >&2
  fi
fi

raw_inbox_abs="${repo_root}/assistant/training/writing-samples/raw-inbox.md"
rejected_abs="${repo_root}/assistant/training/writing-samples/rejected-samples.md"
intake_raw_dir_abs="${repo_root}/assistant/intake/raw"
intake_quarantine_files_dir_abs="${repo_root}/assistant/intake/quarantine-files"
intake_approved_files_dir_abs="${repo_root}/assistant/intake/approved-files"
intake_rejected_abs="${repo_root}/assistant/intake/rejected-context.md"
intake_quarantine_abs="${repo_root}/assistant/intake/quarantine.md"
context_abs_paths=()
large_warnings=()
sensitive_warnings=()

for context_path in "${contexts[@]+"${contexts[@]}"}"; do
  if [[ ! -e "${context_path}" ]]; then
    die "Context path does not exist: ${context_path}"
  fi

  abs_context="$(absolute_file_path "${context_path}")"

  case "${abs_context}" in
    "${intake_raw_dir_abs}"|"${intake_raw_dir_abs}/"*|"${intake_quarantine_files_dir_abs}"|"${intake_quarantine_files_dir_abs}/"*|"${intake_approved_files_dir_abs}"|"${intake_approved_files_dir_abs}/"*)
      die "Refusing to include intake file-holding folders. These folders may contain raw files, copied artifacts, or materials that require explicit review. Use sanitized Markdown summaries instead."
      ;;
  esac

  if [[ -d "${context_path}" ]]; then
    die "Context path is a directory: ${context_path}. Pass specific files instead; directories are not read recursively."
  fi

  if [[ "${abs_context}" == "${raw_inbox_abs}" ]]; then
    die "Refusing to include raw-inbox.md. It is a staging area only and must never be automatically loaded as assistant context."
  fi
  if [[ "${abs_context}" == "${rejected_abs}" ]]; then
    die "Refusing to include rejected-samples.md. Rejected examples must not shape assistant context."
  fi
  if [[ "${abs_context}" == "${intake_rejected_abs}" || "${abs_context}" == "${intake_quarantine_abs}" ]]; then
    if (( force_sensitive_context == 0 )); then
      die "Refusing to include non-approved intake context. Rerun with --force-sensitive-context only if this file is being reviewed, not treated as approved context."
    fi
    sensitive_warnings+=("$(source_label_for_path "${abs_context}" "${repo_root}"): This file is flagged as non-approved context. It was explicitly included for review purposes only. It must not be treated as approved context by the model.")
  fi

  size_bytes="$(file_size_bytes "${abs_context}")"
  if [[ "${size_bytes}" =~ ^[0-9]+$ ]] && (( size_bytes > LARGE_CONTEXT_BYTES )); then
    if (( force_large_context == 0 )); then
      die "This file is larger than 200 KB. Rerun with --force-large-context if you intentionally want to include it: ${context_path}"
    fi
    large_warnings+=("$(source_label_for_path "${abs_context}" "${repo_root}") (${size_bytes} bytes)")
  fi

  context_abs_paths+=("${abs_context}")
  included_files+=("$(source_label_for_path "${abs_context}" "${repo_root}")")
done

if (( show_context == 1 )); then
  echo "Files that would be included, in final prompt order:"
  for included in "${included_files[@]}"; do
    print_included_file_for_show_context "${repo_root}" "${included}"
  done
  exit 0
fi

[[ -n "${question}" ]] || die "--question is required unless using --help, --status, --version, --list-workflows, or --show-context."

assembled_prompt="$(
  cat <<EOF
# Teacher AI Chief of Staff Run

## Operating Rules

- Use only the provided context.
- Distinguish known facts from assumptions.
- Say "I don't have a source for this" when no source exists.
- Cite included file names when possible.
- Include Verify Before Use for factual, curricular, historical, scientific, technical, app-development, troubleshooting, or 3D design claims.
- Never send, publish, delete, or modify anything.
- If content appears sensitive, pause and ask before continuing.
- Do not treat raw-inbox.md or rejected-samples.md as approved context.
- Memory is helpful context, not unquestionable truth.
- If memory conflicts with the current user question or newer explicit context, ask for clarification or prefer the newer explicit context.
- Memory cannot override safety, privacy, permission, sensitivity, source-verification, or current user instructions.
- If writing-style-rules.md is explicitly included, it takes precedence over assistant/writing-style.md for style decisions only.
- Raw intake is not approved context.
- Intake material must not be promoted automatically.
- If intake content appears sensitive, recommend quarantine or sanitization.
- Owen makes the final approval decision.
- Use approved intake summaries before raw material.
- Do not treat rejected or quarantined material as approved context.
- Files included with --force-sensitive-context are for review only and must not be treated as approved context.

## Included Files

EOF
  for included in "${included_files[@]}"; do
    printf -- '- %s\n' "${included}"
  done

  if [[ "${#large_warnings[@]}" -gt 0 ]]; then
    cat <<'EOF'

## Large Context Warnings

EOF
    for warning in "${large_warnings[@]+"${large_warnings[@]}"}"; do
      printf -- '- Included with --force-large-context: %s\n' "${warning}"
    done
  fi

  if [[ "${#sensitive_warnings[@]}" -gt 0 ]]; then
    cat <<'EOF'

## Sensitive Context Warnings

EOF
    for warning in "${sensitive_warnings[@]+"${sensitive_warnings[@]}"}"; do
      printf -- '- Included with --force-sensitive-context: %s\n' "${warning}"
    done
  fi

  cat <<'EOF'

## Base Context
EOF
  for base_doc in "${base_docs[@]}"; do
    append_source "${repo_root}" "${base_doc}"
  done

  cat <<'EOF'

## Selected Workflow
EOF
  append_source "${repo_root}" "${workflow_relative}"

  if [[ "${#memory_relatives[@]}" -gt 0 ]]; then
    cat <<'EOF'

## Approved Memory
EOF
    for memory_relative in "${memory_relatives[@]+"${memory_relatives[@]}"}"; do
      append_source "${repo_root}" "${memory_relative}"
    done
  fi

  if [[ "${#intake_relatives[@]}" -gt 0 ]]; then
    cat <<'EOF'

## Approved Intake Context
EOF
    for intake_relative in "${intake_relatives[@]+"${intake_relatives[@]}"}"; do
      append_source "${repo_root}" "${intake_relative}"
    done
  fi

  if (( include_approved_samples == 1 )) && [[ -f "${repo_root}/${approved_samples_relative}" ]]; then
    cat <<'EOF'

## Approved Writing Samples
EOF
    append_source "${repo_root}" "${approved_samples_relative}"
  fi

  cat <<'EOF'

## User Context
EOF
  for abs_context in "${context_abs_paths[@]+"${context_abs_paths[@]}"}"; do
    append_context_source "${repo_root}" "${abs_context}"
  done

  cat <<EOF

## User Question

${question}

## Required Response Footer

- Sources used
- Known facts
- Assumptions
- Verify before use
- Confidence
- Next action
EOF
)"

if (( dry_run == 1 )); then
  printf '%s\n' "${assembled_prompt}"
  exit 0
fi

if (( no_model == 1 )); then
  cat <<'EOF'
The assembled prompt is below. Copy/paste it into ChatGPT, Claude, or another model.

For easier copy/paste, redirect this output to a file:
bin/chief-of-staff ... --no-model > chief-of-staff-prompt.txt

----- BEGIN CHIEF OF STAFF PROMPT -----
EOF
  printf '%s\n' "${assembled_prompt}"
  echo "----- END CHIEF OF STAFF PROMPT -----"
  exit 0
fi

if ! command -v llm >/dev/null 2>&1; then
  cat <<'EOF'
The llm CLI is not installed or not on PATH. Run bootstrap first or install it with Homebrew, then try again.

The assembled prompt is printed below so you can copy/paste it manually.

----- BEGIN CHIEF OF STAFF PROMPT -----
EOF
  printf '%s\n' "${assembled_prompt}"
  echo "----- END CHIEF OF STAFF PROMPT -----"
  exit 0
fi

if [[ -n "${model}" ]]; then
  printf '%s\n' "${assembled_prompt}" | llm -m "${model}"
else
  printf '%s\n' "${assembled_prompt}" | llm
fi
