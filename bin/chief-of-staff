      exit 0
      ;;
    --wallpaper-photo-image-processing-plan-validator)
      repo_root="$(resolve_repo_root)"
      wallpaper_image_processing_plan_validator_script="${repo_root}/scripts/wallpaper-photo-image-processing-plan-validator.sh"
