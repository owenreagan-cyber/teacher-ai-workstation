      fi
      shift
      bash "${wallpaper_image_processing_plan_validator_script}" "$@"
      exit 0
      ;;
    --wallpaper-photo-scheduler-foundation-status)
      repo_root="$(resolve_repo_root)"
      wallpaper_scheduler_foundation_status_script="${repo_root}/scripts/wallpaper-photo-scheduler-foundation-status.sh"
