        die "Wallpaper photo scheduler foundation status script is missing: scripts/wallpaper-photo-scheduler-foundation-status.sh"
      fi
      bash "${wallpaper_scheduler_foundation_status_script}"
      exit 0
      ;;
    --wallpaper-photo-scheduler-run-plan-validator)
      repo_root="$(resolve_repo_root)"
      wallpaper_scheduler_run_plan_validator_script="${repo_root}/scripts/wallpaper-photo-scheduler-run-plan-validator.sh"
      if [[ ! -f "${wallpaper_scheduler_run_plan_validator_script}" ]]; then
        die "Wallpaper photo scheduler run plan validator script is missing: scripts/wallpaper-photo-scheduler-run-plan-validator.sh"
      fi
      shift
      bash "${wallpaper_scheduler_run_plan_validator_script}" "$@"
      exit 0
      ;;
    --wallpaper-photo-notification-foundation-status)
      repo_root="$(resolve_repo_root)"
      wallpaper_notification_foundation_status_script="${repo_root}/scripts/wallpaper-photo-notification-foundation-status.sh"
      if [[ ! -f "${wallpaper_notification_foundation_status_script}" ]]; then
        die "Wallpaper photo notification foundation status script is missing: scripts/wallpaper-photo-notification-foundation-status.sh"
      fi
      bash "${wallpaper_notification_foundation_status_script}"
      exit 0
      ;;
    --wallpaper-photo-notification-plan-validator)
      repo_root="$(resolve_repo_root)"
