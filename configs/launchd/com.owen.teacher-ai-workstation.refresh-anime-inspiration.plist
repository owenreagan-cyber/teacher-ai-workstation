<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.owen.teacher-ai-workstation.refresh-anime-inspiration</string>

  <key>ProgramArguments</key>
  <array>
    <string>__REPO_PATH__/scripts/refresh-anime-inspiration.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__REPO_PATH__</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>6</integer>
    <key>Hour</key>
    <integer>10</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/teacher-ai-workstation/refresh-anime-inspiration.out.log</string>

  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/teacher-ai-workstation/refresh-anime-inspiration.err.log</string>
</dict>
</plist>
